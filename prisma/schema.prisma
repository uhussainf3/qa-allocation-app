generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth required models

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// User — role: ADMIN | EXECUTIVE | DIVISION_OWNER | PROJECT_MANAGER | MEMBER
//        jobTitle: DEVELOPER | QA_ENGINEER | FUNCTIONAL_CONSULTANT | SUPPORT_ENGINEER | PROJECT_MANAGER | PRODUCT_MANAGER

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("MEMBER")
  jobTitle      String?   // DEVELOPER | QA_ENGINEER | FUNCTIONAL_CONSULTANT | SUPPORT_ENGINEER | PROJECT_MANAGER | PRODUCT_MANAGER
  isActive      Boolean   @default(true)
  isOnshore     Boolean   @default(false)
  capacity      Int       @default(40)
  department    String?
  divisionId    String?
  managerId     String?            // Direct manager / PM (FK → User.id, set from Director ID in RM data)
  externalId    String?   @unique  // FomsId from RM tool
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  division                 Division?         @relation("DivisionMembers", fields: [divisionId], references: [id])
  manager                  User?             @relation("ManagedBy", fields: [managerId], references: [id], onDelete: SetNull)
  managedUsers             User[]            @relation("ManagedBy")
  ownedDivisions           Division[]        @relation("DivisionOwner")
  accounts                 Account[]
  sessions                 Session[]
  allocations              Allocation[]
  allocationBatches        AllocationBatch[]
  hoursLogs                HoursLog[]
  leaveRequests            Leave[]
  skills                   UserSkill[]
  auditLogs                AuditLog[]
  notifications            Notification[]
  resourceRequestsCreated  ResourceRequest[] @relation("RequestCreatedBy")
  resourceRequestsAssigned ResourceRequest[] @relation("RequestAssignedTo")
  timesheets               Timesheet[]
  assignedTasks            Task[]            @relation("AssignedTasks")
}

// Division — top-level organisational unit (e.g. NetSuite, App Dev, ML/AI)

model Division {
  id          String   @id @default(cuid())
  name        String
  code        String   @unique   // e.g. "NS", "AD", "ML"
  color       String   @default("#6366f1")
  description String?
  ownerId     String?            // Division Owner (User)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  owner    User?     @relation("DivisionOwner", fields: [ownerId], references: [id])
  projects Project[]
  members  User[]    @relation("DivisionMembers")
}

// Project — status: ACTIVE | ON_HOLD | COMPLETED | CANCELLED

model Project {
  id              String   @id @default(cuid())
  name            String
  code            String   @unique
  description     String?
  clientName      String?
  status          String   @default("ACTIVE")
  sanctionedHours Float    @default(0)
  startDate       DateTime?
  endDate         DateTime?
  color           String   @default("#6366f1")
  divisionId      String?
  externalId      String?  @unique  // ProjectID from RM tool
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  division         Division?         @relation(fields: [divisionId], references: [id])
  tasks            Task[]
  allocations      Allocation[]
  hoursLogs        HoursLog[]
  resourceRequests ResourceRequest[]
  auditLogs        AuditLog[]
}

model Task {
  id             String    @id @default(cuid())
  name           String
  description    String?
  projectId      String
  parentId       String?
  assignedUserId String?
  status         String    @default("TODO")      // TODO | IN_PROGRESS | IN_REVIEW | DONE | BLOCKED
  priority       String    @default("MEDIUM")    // LOW | MEDIUM | HIGH | CRITICAL
  estimatedHours Float     @default(0)
  dueDate        DateTime?
  jiraId         String?                         // Jira issue ID (future integration)
  jiraKey        String?                         // e.g. "QA-123"
  order          Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project      Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  parent       Task?        @relation("SubTasks", fields: [parentId], references: [id])
  subtasks     Task[]       @relation("SubTasks")
  assignedUser User?        @relation("AssignedTasks", fields: [assignedUserId], references: [id])
  allocations  Allocation[]
  hoursLogs    HoursLog[]
}

model AllocationBatch {
  id           String       @id @default(cuid())
  label        String
  uploadedAt   DateTime     @default(now())
  uploadedById String
  isCurrent    Boolean      @default(false)
  sourceFile   String
  log          Json?

  uploadedBy   User         @relation(fields: [uploadedById], references: [id])
  allocations  Allocation[]
}

model Allocation {
  id           String   @id @default(cuid())
  userId       String
  projectId    String
  taskId       String?
  batchId      String?
  startDate    DateTime
  endDate      DateTime
  hoursPerDay  Float    @default(8)
  notes        String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user    User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  project Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?            @relation(fields: [taskId], references: [id])
  batch   AllocationBatch? @relation(fields: [batchId], references: [id])

  @@unique([userId, projectId, startDate])
}

// HoursLog — status: DRAFT | SUBMITTED | APPROVED | REJECTED

model HoursLog {
  id          String   @id @default(cuid())
  userId      String
  projectId   String
  taskId      String?
  date        DateTime
  hours       Float
  notes       String?
  status      String   @default("DRAFT")
  timesheetId String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task      Task?      @relation(fields: [taskId], references: [id])
  timesheet Timesheet? @relation(fields: [timesheetId], references: [id])
}

// Timesheet — status: PENDING | SUBMITTED | APPROVED | REJECTED | FLAGGED

model Timesheet {
  id          String    @id @default(cuid())
  userId      String
  weekStart   DateTime
  totalHours  Float     @default(0)
  status      String    @default("PENDING")
  reviewNote  String?
  reviewedAt  DateTime?
  reviewedBy  String?
  submittedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  hoursLogs HoursLog[]

  @@unique([userId, weekStart])
}

// Leave — type: PTO | SICK | TRAINING | PUBLIC_HOLIDAY | UNPAID
//         status: PENDING | APPROVED | REJECTED

model Leave {
  id         String   @id @default(cuid())
  userId     String
  type       String
  startDate  DateTime
  endDate    DateTime
  reason     String?
  status     String   @default("PENDING")
  approvedBy String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Skill {
  id       String      @id @default(cuid())
  name     String      @unique
  category String?
  users    UserSkill[]
}

model UserSkill {
  id      String @id @default(cuid())
  userId  String
  skillId String
  level   Int    @default(1)

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([userId, skillId])
}

// ResourceRequest — priority: CRITICAL | HIGH | MEDIUM | LOW
//                   status: PENDING | APPROVED | DECLINED | FULFILLED

model ResourceRequest {
  id             String    @id @default(cuid())
  projectId      String?
  requestedById  String
  assignedToId   String?
  title          String
  description    String?
  skillsRequired String?
  hoursPerWeek   Float     @default(0)
  startDate      DateTime?
  duration       Int?
  priority       String    @default("MEDIUM")
  status         String    @default("PENDING")
  notes          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  project     Project? @relation(fields: [projectId], references: [id])
  requestedBy User     @relation("RequestCreatedBy", fields: [requestedById], references: [id])
  assignedTo  User?    @relation("RequestAssignedTo", fields: [assignedToId], references: [id])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  targetType String
  targetId   String?
  projectId  String?
  details    String?
  createdAt  DateTime @default(now())

  actor   User?    @relation(fields: [actorId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}

// Notification — type: OVER_ALLOCATION | LEAVE_REQUEST | TIMESHEET_SUBMITTED |
//                      TIMESHEET_APPROVED | TIMESHEET_REJECTED | RESOURCE_REQUEST |
//                      PROJECT_UPDATE | SYSTEM

model Notification {
  id        String   @id @default(cuid())
  userId    String
  type      String
  title     String
  message   String
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationPreference {
  id     String @id @default(cuid())
  userId String @unique
  prefs  String
}

// Pipeline — status: LEAD | QUALIFIED | PROPOSAL | NEGOTIATION | WON | LOST
model Pipeline {
  id                 String    @id @default(cuid())
  name               String
  clientName         String?
  status             String    @default("LEAD")
  probability        Int       @default(50)   // 0–100 %
  dealSize           Float?                   // estimated budget
  expectedStartDate  DateTime?
  expectedEndDate    DateTime?
  requiredHeadcount  Int       @default(1)
  hoursPerWeek       Float     @default(40)
  skillsRequired     String?
  notes              String?
  convertedProjectId String?                  // Project.id once converted
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// Public holidays — excluded from working-day calculations
model PublicHoliday {
  id        String   @id @default(cuid())
  date      DateTime // stored at UTC midnight
  name      String
  createdAt DateTime @default(now())

  @@unique([date])
}

// Job Titles — admin-managed list; value stored as User.jobTitle (String)
model JobTitle {
  id        String   @id @default(cuid())
  name      String   @unique  // e.g. "QA Engineer", "Developer"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
